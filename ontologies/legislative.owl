@prefix : <http://www.oireachtas.ie/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@base <http://www.oireachtas.ie/ontology/legislative> .

<http://www.oireachtas.ie/ontology/legislative> rdf:type owl:Ontology ;

    rdfs:comment "Legislative Documents ontology for the Houses of the Oireachtas: Bills, Acts, versions, expressions and formats."@en ;

    owl:imports <http://www.oireachtas.ie/ontology/events> ,
                <http://data.europa.eu/eli/ontology#> ,
                <http://www.metalex.eu/metalex/2008-05-02> .


#################################################################
#
#    Data Properties
#
#################################################################


###  http://www.oireachtas.ie/ontology#OriginalTitle

:OriginalTitle rdf:type owl:DatatypeProperty ;

               rdfs:label "Original title" ;

               rdfs:comment "The title of a LegalResource when first published" ;

               rdfs:subPropertyOf dct:alternative .


#################################################################
#
#    Classes
#
#################################################################


###  http://www.oireachtas.ie/ontology#BillResource

:BillResource rdf:type owl:Class ;

              rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalResource> ,
                              <http://www.metalex.eu/metalex/2008-05-02#BibliographicWork> .


###  http://www.oireachtas.ie/ontology#BillExpression

:BillExpression rdf:type owl:Class ;

                rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalExpression> ,
                                <http://www.metalex.eu/metalex/2008-05-02#BibliographicExpression> .


###  http://www.oireachtas.ie/ontology#BillFormat

:BillFormat rdf:type owl:Class ;

            rdfs:subClassOf <http://data.europa.eu/eli/ontology#Format> ,
                            <http://www.metalex.eu/metalex/2008-05-02#BibliographicManifestation> .


###  http://www.oireachtas.ie/ontology#BillVersion

:BillVersion rdf:type owl:Class ;

             rdfs:subClassOf <http://data.europa.eu/eli/ontology#Version> .


###  http://www.oireachtas.ie/ontology#BillsBook

:BillsBook rdf:type owl:Class ;

           rdfs:subClassOf skos:OrderedCollection ;

           skos:prefLabel "Bills Book"@en ;

           skos:altLabel "Legislative Observatory"@en .


###  http://www.oireachtas.ie/ontology#AmendmentList

:AmendmentList rdf:type owl:Class ;

               rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalResource> ,
                               <http://www.metalex.eu/metalex/2008-05-02#BibliographicWork> .


###  http://www.oireachtas.ie/ontology#BillAmendment
###  Hybrid: primary identity as a LegalExpression; inherits AmendingStage from events.owl

:BillAmendment rdf:type owl:Class ;

               rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalExpression> ,
                               :AmendingStage ;

               rdfs:comment "An amendment is both an expression (or perhaps a work) and a modifying event"@en ;

               skos:prefLabel "Bill Amendment"@en .


###  http://www.oireachtas.ie/ontology#BillStatus

:BillStatus rdf:type owl:Class ;

            skos:prefLabel "Bill Status"@en ;

            rdfs:comment "The current or most recent status of a Bill"@en .


#################################################################
#
#    Annotations on imported ELI properties
#
#################################################################

<http://data.europa.eu/eli/ontology#title_alternative> rdfs:label "Long title of a Bill"@en .

<http://data.europa.eu/eli/ontology#title> rdfs:label "Short title of a Bill" .

<http://data.europa.eu/eli/ontology#basis_for> rdfs:comment "A Bill is the basis for an Act" .


#################################################################
#
#    Individuals — ELI Resource Types
#
#################################################################


###  http://www.oireachtas.ie/ontology#Act

:Act rdf:type <http://data.europa.eu/eli/ontology#ResourceType> ,
              owl:NamedIndividual ;

     skos:prefLabel "Act"@en ;

     skos:topConceptOf <http://data.europa.eu/eli/ontology#ResourceTypeTable> ;

     skos:inScheme <http://data.europa.eu/eli/ontology#ResourceTypeTable> .


###  http://www.oireachtas.ie/ontology#Bill

:Bill rdf:type <http://data.europa.eu/eli/ontology#ResourceType> ,
               owl:NamedIndividual ;

      skos:prefLabel "Bill"@en ;

      skos:inScheme <http://data.europa.eu/eli/ontology#ResourceTypeTable> ;

      skos:topConceptOf <http://data.europa.eu/eli/ontology#ResourceTypeTable> .


###  http://www.oireachtas.ie/ontology#DraftBill

:DraftBill rdf:type <http://data.europa.eu/eli/ontology#ResourceType> ,
                    owl:NamedIndividual ;

           skos:prefLabel "Heads of Bill"@en ;

           skos:inScheme <http://data.europa.eu/eli/ontology#ResourceTypeTable> ;

           skos:topConceptOf <http://data.europa.eu/eli/ontology#ResourceTypeTable> .


###  http://www.oireachtas.ie/ontology#ExplanatoryMemo

:ExplanatoryMemo rdf:type <http://data.europa.eu/eli/ontology#ResourceType> ,
                          owl:NamedIndividual ;

                 skos:prefLabel "Explanatory Memorandum"@en ;

                 skos:topConceptOf <http://data.europa.eu/eli/ontology#ResourceTypeTable> ;

                 skos:inScheme <http://data.europa.eu/eli/ontology#ResourceTypeTable> .


#################################################################
#
#    Individuals — Bill Versions
#
#################################################################


###  http://www.oireachtas.ie/ontology#AsInitiated

:AsInitiated rdf:type :BillVersion ,
                      owl:NamedIndividual ;

             skos:prefLabel "As Initiated"@en ;

             skos:topConceptOf <http://data.europa.eu/eli/ontology#VersionTable> ;

             skos:inScheme <http://data.europa.eu/eli/ontology#VersionTable> .

[ rdf:type owl:Axiom ;
  skos:prefLabel "Bill as initiated"@en ;
  owl:annotatedSource :AsInitiated ;
  owl:annotatedTarget :BillVersion ;
  owl:annotatedProperty rdf:type
] .


###  http://www.oireachtas.ie/ontology#VersionA

:VersionA rdf:type :BillVersion ,
                   owl:NamedIndividual ;

          skos:prefLabel "Second Printing"@en ;

          skos:inScheme <http://data.europa.eu/eli/ontology#VersionTable> ;

          skos:topConceptOf <http://data.europa.eu/eli/ontology#VersionTable> .

[ rdf:type owl:Axiom ;
  skos:prefLabel "Second printing"@en ;
  rdfs:comment "The second version of a Bill after being amended for the first time."@en ;
  owl:annotatedTarget :BillVersion ;
  owl:annotatedSource :VersionA ;
  owl:annotatedProperty rdf:type
] .


###  http://www.oireachtas.ie/ontology#VersionB

:VersionB rdf:type :BillVersion ,
                   owl:NamedIndividual ;

          skos:prefLabel "Third Printing"@en ;

          skos:topConceptOf <http://data.europa.eu/eli/ontology#VersionTable> ;

          skos:inScheme <http://data.europa.eu/eli/ontology#VersionTable> .

[ rdf:type owl:Axiom ;
  skos:prefLabel "Third Printing"@en ;
  rdfs:comment "Third version of Bill, having been amended for the second time."@en ;
  owl:annotatedTarget :BillVersion ;
  owl:annotatedSource :VersionB ;
  owl:annotatedProperty rdf:type
] .


###  http://www.oireachtas.ie/ontology#VersionC

:VersionC rdf:type :BillVersion ,
                   owl:NamedIndividual ;

          skos:prefLabel "Fourth Printing"@en ;

          skos:inScheme <http://data.europa.eu/eli/ontology#VersionTable> ;

          skos:topConceptOf <http://data.europa.eu/eli/ontology#VersionTable> .

[ rdf:type owl:Axiom ;
  rdfs:comment "Fourth Printing"@en ,
               "Fourth version of Bill, having been amended for the third time."@en ;
  owl:annotatedTarget :BillVersion ;
  owl:annotatedSource :VersionC ;
  owl:annotatedProperty rdf:type
] .


###  http://www.oireachtas.ie/ontology#VersionD

:VersionD rdf:type :BillVersion ,
                   owl:NamedIndividual ;

          skos:prefLabel "Fifth Printing"@en ;

          skos:topConceptOf <http://data.europa.eu/eli/ontology#VersionTable> ;

          skos:inScheme <http://data.europa.eu/eli/ontology#VersionTable> .


#################################################################
#
#    Individuals — Bill Statuses
#
#################################################################


###  http://www.oireachtas.ie/ontology#AwaitingSignatureBill

:AwaitingSignatureBill rdf:type :BillStatus ,
                                owl:NamedIndividual ;

                       skos:prefLabel "Passed, awaiting President's signature"@en ;

                       skos:topConceptOf :BillStatusTable ;

                       skos:inScheme :BillStatusTable .


###  http://www.oireachtas.ie/ontology#CurrentBill

:CurrentBill rdf:type :BillStatus ,
                      owl:NamedIndividual ;

             skos:prefLabel "Current"@en ;

             skos:inScheme :BillStatusTable ;

             skos:topConceptOf :BillStatusTable .


###  http://www.oireachtas.ie/ontology#DefeatedBill

:DefeatedBill rdf:type :BillStatus ,
                       owl:NamedIndividual ;

              skos:prefLabel "Defeated"@en ;

              skos:topConceptOf :BillStatusTable ;

              skos:inScheme :BillStatusTable .


###  http://www.oireachtas.ie/ontology#DraftHeadsOfBill

:DraftHeadsOfBill rdf:type :BillStatus ,
                           owl:NamedIndividual ;

                  skos:prefLabel "Heads drafted"@en ;

                  skos:topConceptOf :BillStatusTable ;

                  skos:inScheme :BillStatusTable .


###  http://www.oireachtas.ie/ontology#EnactedBill

:EnactedBill rdf:type :BillStatus ,
                      owl:NamedIndividual ;

             skos:prefLabel "Enacted"@en ;

             skos:inScheme :BillStatusTable ;

             skos:topConceptOf :BillStatusTable .


###  http://www.oireachtas.ie/ontology#LapsedBill

:LapsedBill rdf:type :BillStatus ,
                     owl:NamedIndividual ;

            skos:prefLabel "Lapsed"@en ;

            skos:topConceptOf :BillStatusTable ;

            skos:inScheme :BillStatusTable .


###  http://www.oireachtas.ie/ontology#RejectedAtReferendumBill

:RejectedAtReferendumBill rdf:type :BillStatus ,
                                   owl:NamedIndividual ;

                          skos:prefLabel "Rejected at referendum"@en ;

                          skos:topConceptOf :BillStatusTable ;

                          skos:inScheme :BillStatusTable .


###  http://www.oireachtas.ie/ontology#SubjectToReferendumBill

:SubjectToReferendumBill rdf:type :BillStatus ,
                                  owl:NamedIndividual ;

                         skos:prefLabel "Passed, subject to referendum"@en ;

                         skos:topConceptOf :BillStatusTable ;

                         skos:inScheme :BillStatusTable .


###  http://www.oireachtas.ie/ontology#WithdrawnBill

:WithdrawnBill rdf:type :BillStatus ,
                        owl:NamedIndividual ;

               skos:prefLabel "Withdrawn"@en ;

               skos:topConceptOf :BillStatusTable ;

               skos:inScheme :BillStatusTable .
