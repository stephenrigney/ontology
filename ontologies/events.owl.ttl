:DeclaredLost rdf:type :BillEventOutcome ,
                       owl:NamedIndividual ;

              skos:prefLabel "Declared lost"@en ;

              skos:topConceptOf :BillEventResultTable ;

              skos:inScheme :BillEventResultTable .


###  https://data.oireachtas.ie/ontology#NotMoved

:NotMoved rdf:type :BillEventOutcome ,
                   owl:NamedIndividual ;

          skos:prefLabel "Not moved"@en ;

          skos:inScheme :BillEventResultTable ;

          skos:topConceptOf :BillEventResultTable .


