           skos:inScheme :BillEventResultTable .


#################################################################
#
#    Individuals — Bill Delivery Methods
#
#################################################################


###  https://data.oireachtas.ie/ontology#Application

:Application rdf:type :BillDelivery ,
                      owl:NamedIndividual ;

             skos:topConceptOf :BillDeliveryTable ;

             skos:inScheme :BillDeliveryTable .


###  https://data.oireachtas.ie/ontology#Introduction

:Introduction rdf:type :BillDelivery ,
                       owl:NamedIndividual ;

              skos:topConceptOf :BillDeliveryTable ;

              skos:inScheme :BillDeliveryTable .


###  https://data.oireachtas.ie/ontology#Presentation

:Presentation rdf:type :BillDelivery ,
                       owl:NamedIndividual ;

              skos:inScheme :BillDeliveryTable ;

              skos:topConceptOf :BillDeliveryTable .


#################################################################
#
#    Individuals — Bill Delivery Outcomes
#
#################################################################


###  https://data.oireachtas.ie/ontology#Examiner

:Examiner rdf:type :BillDeliveryOutcome ,
                   owl:NamedIndividual ;

          skos:prefLabel "Report of the Examiner of Private Bills"@en .


###  https://data.oireachtas.ie/ontology#Introduced

:Introduced rdf:type :BillDeliveryOutcome ,
                     owl:NamedIndividual ;

            skos:prefLabel "Introduced"@en .


###  https://data.oireachtas.ie/ontology#Presented

:Presented rdf:type :BillDeliveryOutcome ,
                    owl:NamedIndividual ;

           skos:prefLabel "Presented"@en .


###  https://data.oireachtas.ie/ontology#Refused

:Refused rdf:type :BillDeliveryOutcome ,
                  owl:NamedIndividual ;

         skos:prefLabel "Refused Introduction"@en .


#################################################################
#
#    Individuals — ELI-DL Activity Types
#
#################################################################


###  https://data.oireachtas.ie/ontology#LegislativeCreationActivity
###  Replaces metalex:LegislativeCreation distinction

:LegislativeCreationActivity rdf:type eli-dl:ActivityType ,
                                      owl:NamedIndividual ;

                             skos:prefLabel "Legislative creation activity"@en ;

                             rdfs:comment "Activity type for general journal/legislative events (used via eli-dl:had_activity_type on JournalEvent instances)"@en .


###  https://data.oireachtas.ie/ontology#LegislativeDeliveryActivity
###  Replaces metalex:LegislativeDelivery distinction

:LegislativeDeliveryActivity rdf:type eli-dl:ActivityType ,
                                      owl:NamedIndividual ;

                             skos:prefLabel "Legislative delivery activity"@en ;

                             rdfs:comment "Activity type for bill delivery/initiation activities (used via eli-dl:had_activity_type on BillDelivery instances)"@en .


###  https://data.oireachtas.ie/ontology#LegislativeModificationActivity
###  Replaces metalex:LegislativeModification distinction

:LegislativeModificationActivity rdf:type eli-dl:ActivityType ,
                                          owl:NamedIndividual ;

                                 skos:prefLabel "Legislative modification activity"@en ;

                                 rdfs:comment "Activity type for amending activities (used via eli-dl:had_activity_type on AmendingStage instances and amendment-related LegislativeActivity instances)"@en .
